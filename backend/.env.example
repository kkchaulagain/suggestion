# Server
PORT=3000

# MongoDB (omit to use in-memory DB in tests)
MONGODB_URI=mongodb://localhost:27017/suggestion

# JWT signing (set in production)
JWT_SECRET=your-secret-key-change-in-production

# Optional: base URL for form link and QR (default: http://localhost:3001/feedback-forms)
FRONTEND_FORM_BASE_URL=http://localhost:3000/feedback-forms
