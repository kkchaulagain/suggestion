# Server
PORT=3000

# MongoDB (omit to use in-memory DB in tests)
MONGODB_URI=mongodb://localhost:27017/suggestion

# JWT signing (set in production)
JWT_SECRET=your-secret-key-change-in-production

# Optional: base URL for form link and QR (default: http://localhost:3001/feedback-forms)
FRONTEND_FORM_BASE_URL=http://localhost:3002/feedback-forms

# Cloudflare R2 (optional – for image uploads in feedback forms)
# Create bucket, enable public access, then add R2 API token in dashboard (see docs/ENV.md)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_BUCKET_NAME=your-bucket-name
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
# Optional: key prefix so dev and prod share one bucket (e.g. dev/ for local)
# R2_KEY_PREFIX=dev/
